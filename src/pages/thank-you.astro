---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Situs Sedang Dipulihkan"
  description="Halaman sementara untuk pemulihan situs."
  ogTitle="Situs Sedang Dipulihkan"
  ogDescription="Kami sedang menyelidiki pemulihan dan cadangan situs Anda."
  lang="id"
>
  <main class="placeholder-page" role="main">
    <div class="placeholder-container">
      <header class="placeholder-header">
        <h1>Situs Sedang Dipulihkan</h1>
      </header>
      <p class="placeholder-message">
        Kami sedang menyelidiki pemulihan dan cadangan situs Anda. Tim kami sedang bekerja untuk mengembalikan akses secepat mungkin. Terima kasih atas kesabaran Anda.
      </p>
      <p class="placeholder-secondary">
        Jika Anda membutuhkan pembaruan, kami akan menginformasikannya di sini saat tersedia.
      </p>
      <footer class="placeholder-footer">
        <small>Halaman sementara — dibuat untuk pemulihan situs.</small>
      </footer>
    </div>
  </main>
</BaseLayout>
